{
    "kind": "collectionType",
    "collectionName": "pages",
    "info": {
        "singularName": "page",
        "pluralName": "pages",
        "displayName": "Page",
        "description": "Static pages like About Us, Privacy Policy, etc."
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true,
            "maxLength": 255
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "content": {
            "type": "richtext",
            "required": true
        },
        "meta_title": {
            "type": "string",
            "maxLength": 255
        },
        "meta_description": {
            "type": "text"
        },
        "is_active": {
            "type": "boolean",
            "default": true
        }
    }
}
