{
    "kind": "collectionType",
    "collectionName": "product_variants",
    "info": {
        "singularName": "product-variant",
        "pluralName": "product-variants",
        "displayName": "Product Variant",
        "description": "Product variants like sizes, colors, materials"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "maxLength": 255
        },
        "size": {
            "type": "string",
            "maxLength": 20
        },
        "color": {
            "type": "string",
            "maxLength": 50
        },
        "material": {
            "type": "string",
            "maxLength": 50
        },
        "price_adjustment": {
            "type": "decimal",
            "default": 0
        },
        "stock_quantity": {
            "type": "integer",
            "default": 0,
            "min": 0
        },
        "sku": {
            "type": "string",
            "unique": true,
            "maxLength": 100
        },
        "is_active": {
            "type": "boolean",
            "default": true
        },
        "product": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::product.product",
            "inversedBy": "variants"
        }
    }
}
